SECRET_KEY=replace-with-a-long-random-secret
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,testserver
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:3000,http://localhost:3000,http://192.168.3.90:3000,http://192.168.186.1:3000
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://192.168.3.90:3000,http://192.168.186.1:3000
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOW_CREDENTIALS=True
DJANGO_SETTINGS_MODULE=config.settings.dev
DATABASE_URL=
TEST_DATABASE_URL=
DB_CONN_MAX_AGE=60
STATIC_ROOT=staticfiles
MEDIA_ROOT=media
LOG_DIR=logs
JWT_ACCESS_LIFETIME_MINUTES=60
JWT_REFRESH_LIFETIME_DAYS=7
INGEST_API_KEY=local-dev-ingest-key
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0

# 局域网调试（dev）：本机 IP，逗号分隔，会并入 ALLOWED_HOSTS
# EXTRA_ALLOWED_HOSTS=192.168.3.90

# Next dev Server：额外允许的 Host（逗号分隔，不含 http://）
# NEXT_DEV_ALLOWED_ORIGINS=10.0.0.5

# 可选：从其它机器访问 Next 时的 Origin（dev.py 已含常用局域网 :3000，此处可追加）
# LAN_FRONTEND_ORIGINS=http://10.0.0.5:3000

# —— 前端 Next（frontend/.env.local）——
# 浏览器请求本应用 BFF：留空则用相对路径 /api（推荐局域网）
# NEXT_PUBLIC_API_BASE_URL=
# Next 服务端代理 Django（与 Django 同机时常用 127.0.0.1）
# DJANGO_BASE_URL=http://127.0.0.1:8000
